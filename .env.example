# TITAN VERITAS v5.0 - Configurazioni Richieste

# 0. Database path (default: titan_veritas.db nella root)
TITAN_DB_PATH=titan_veritas.db

# 1. Google Gemini API (Per il processing delle risposte)
GEMINI_API_KEY=tua_chiave_gemini

# 2. Telegram Bot (Per le notifiche real-time)
TELEGRAM_BOT_TOKEN=tua_token_bot
TELEGRAM_CHAT_ID=tua_chat_id

# 3. Google Cloud Console (Per Gmail API)
# È necessario creare un progetto e scaricare 'credentials.json' nella root.
GMAIL_CREDENTIALS_FILE=credentials.json
GMAIL_TOKEN_FILE=token.json
